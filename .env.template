# APP SETTINGS
APP_ENV=local
BASEMENT_PASSWORD=
CRON_SECRET=
# Default: Database is required. Set to 0 to disable for unit tests.
REQUIRE_DATABASE=1
# Non-destructive init. Set to 1 to DROP tables during init-db.
BASEMENT_DB_RESET=0

# DATABASE (Pooled / Runtime)
# For Vercel/Neon, populate ONE of these. Priority: DATABASE_URL > POSTGRES_URL
DATABASE_URL=
# Or Vercel managed:
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# DATABASE (Unpooled / Migration)
# Used for direct connections (migrations, scripts).
DATABASE_URL_UNPOOLED=
# Or Vercel managed:
# POSTGRES_URL_NON_POOLING=

# EXTERNAL SERVICES
ODDS_API_KEY=
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DraftKings Ingest Agent
EGRESS_MODE=restricted
# Set NEON_HOST to your Neon hostname (e.g., ep-xxx.us-east-2.aws.neon.tech)
# or derive from DATABASE_URL. Used to expand ${NEON_HOST} in the allowlist.
NEON_HOST=
EGRESS_ALLOWLIST=draftkings.com,sportsbook.draftkings.com,${NEON_HOST}

# Absolute path to persistent Chrome profile (used by sync worker scraper)
DK_PROFILE_PATH=/absolute/path/to/persistent/chrome/profile

# Settled bets scrape tuning
DK_SCROLL_PAGES=5
NEWER_THAN_DAYS=7
MAX_BETS_PER_RUN=50

# Worker poll interval (seconds)
SYNC_WORKER_POLL_SECONDS=10
