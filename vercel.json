{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "rewrites": [
        {
            "source": "/api/:match*",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/**/*.py": {
            "excludeFiles": "{tests/**,docs/**,scripts/**,client/**,data/**,**/*.db,**/*.parquet,node_modules/**,venv/**,.venv/**,chrome_profile/**,chrome_profile_fd/**,playwright_profile_fd/**,test_profile/**}",
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/jobs/policy_refresh",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/jobs/ingest_torvik",
            "schedule": "0 7 * * *"
        },
        {
            "path": "/api/jobs/build_daily_top_picks",
            "schedule": "15 7 * * *"
        },
        {
            "path": "/api/jobs/ingest_results/NCAAM",
            "schedule": "30 7 * * *"
        },
        {
            "path": "/api/jobs/reconcile",
            "schedule": "45 7 * * *"
        },
        {
            "path": "/api/jobs/grade_predictions",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/jobs/run_council_today",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/jobs/queue_sync/draftkings",
            "schedule": "0 7 * * *"
        }
    ]
}